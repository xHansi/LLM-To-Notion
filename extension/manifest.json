{
  "manifest_version": 3,
  "name": "LLM to Notion – Math & LaTeX",
  "description": "Copy AI answers with LaTeX math into Notion without breaking formulas or formatting.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "icons": {
    "16": "images/llm-to-notion.png",
    "32": "images/llm-to-notion.png",
    "48": "images/llm-to-notion.png",
    "128": "images/llm-to-notion.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/llm-to-notion.png",
      "32": "images/llm-to-notion.png",
      "48": "images/llm-to-notion.png"
    }
  },
  "content_scripts": [
    {
      "js": ["./content.js"],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_end",
      "all_frames": true
    },
    {
      "css": ["./content.css"],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
